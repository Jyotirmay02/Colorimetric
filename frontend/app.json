{
  "expo": {
    "name": "Chromalyze",
    "slug": "chromalyze",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "chromalyze",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.spectrallab.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Capture solution photos for RGB analysis",
        "NSPhotoLibraryUsageDescription": "Select solution photos for RGB analysis"
      }
    },
    "android": {
      "package": "com.spectrallab.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#1C1C4C"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Capture solution photos for RGB analysis"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Select solution photos for RGB analysis"
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 220,
          "resizeMode": "contain",
          "backgroundColor": "#1C1C4C"
        }
      ],
      "expo-web-browser",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
